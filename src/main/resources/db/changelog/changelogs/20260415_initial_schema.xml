<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="20231009000500" author="jicay">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="livres"/>
            </not>
        </preConditions>

        <createTable tableName="livres">
            <column name="id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="author" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="reserved" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey columnNames="id" tableName="livres"/>
        <addAutoIncrement tableName="livres" columnName="id" columnDataType="int"/>
    </changeSet>

</databaseChangeLog>